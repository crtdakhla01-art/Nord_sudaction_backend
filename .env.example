APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=false
APP_URL=http://localhost

# Comma-separated allowed frontend origins for credentialed CORS requests.
# Example (production): CORS_ALLOWED_ORIGINS=https://www.nordsudaction.org,https://nordsudaction.org
# Example (local): CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
CORS_ALLOWED_ORIGINS=

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"
CONTACT_RECIPIENT_EMAIL=contact@nordsudaction.org

EMAIL_DELIVERY_DRIVER=brevo_api
BREVO_API_KEY=
BREVO_API_BASE_URL=https://api.brevo.com
EMAIL_BREVO_TIMEOUT_SECONDS=15
EMAIL_BREVO_CONNECT_TIMEOUT_SECONDS=5

NEWSLETTER_PUBLIC_BASE_URL=https://www.nordsudaction.ma
NEWSLETTER_UNSUBSCRIBE_BASE_URL="${APP_URL}"
NEWSLETTER_UNSUBSCRIBE_MAILTO="${MAIL_FROM_ADDRESS}"
NEWSLETTER_SEND_DELAY_SECONDS=0
NEWSLETTER_BREVO_USE_BATCH=false
NEWSLETTER_BREVO_ENABLE_LIST_UNSUBSCRIBE_HEADERS=false
NEWSLETTER_BREVO_BATCH_SIZE=100

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
